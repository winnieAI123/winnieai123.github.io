---
import { getCollection, render } from "astro:content";
import AppLayout from "../layouts/AppLayout.astro";
import ProjectDetail from "../components/ProjectDetail.astro";
import { site, domains, categories } from "../data/site";

const all = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
const rendered = await Promise.all(
  all.map(async (p) => ({ p, Content: (await render(p)).Content })),
);

const DEFAULT_DOMAIN = "work";
const firstActive = all.find((p) => p.data.domain === DEFAULT_DOMAIN) ?? all[0];
const counts = Object.fromEntries(
  domains.map((d) => [d.key, all.filter((p) => p.data.domain === d.key).length]),
);
---

<AppLayout>
  <div class="app" data-mobile-view="list">
    <h1 class="sr-only">Winnie · AI-native Builder 作品集</h1>
    <!-- 顶栏 -->
    <header class="topbar">
      <a class="brand" href="/">
        <span class="brand__name">Winnie<span class="brand__dot">.</span></span>
        <span class="brand__role">AI-native Builder</span>
      </a>

      <nav class="tabs" role="tablist" aria-label="项目分类">
        {
          domains.map((d) => (
            <button
              class:list={["tab", { "is-active": d.key === DEFAULT_DOMAIN }]}
              data-tab={d.key}
              role="tab"
              aria-selected={d.key === DEFAULT_DOMAIN ? "true" : "false"}
            >
              {d.label}
              <span class="tab__count">{counts[d.key]}</span>
            </button>
          ))
        }
      </nav>

      <div class="contact">
        <a href={`mailto:${site.email}`}>Email</a>
        <a href={site.github} target="_blank" rel="noopener">GitHub</a>
        <a href={site.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </header>

    <div class="main">
      <!-- 左栏：项目列表 -->
      <aside class="sidebar" aria-label="项目列表">
        {
          domains.map((dm) => (
            <div class="list-group" data-domain={dm.key} hidden={dm.key !== DEFAULT_DOMAIN}>
              {categories.map((cat) => {
                const items = all.filter(
                  (p) => p.data.domain === dm.key && p.data.category === cat.key,
                );
                if (items.length === 0) return null;
                return (
                  <div class="list-cat">
                    <p class="list-cat__label">{cat.label}</p>
                    {items.map((p) => (
                      <button
                        class:list={[
                          "item",
                          { "is-active": p.id === firstActive.id },
                        ]}
                        data-slug={p.id}
                        data-domain={dm.key}
                      >
                        <span class="item__title">{p.data.title}</span>
                        <span class="item__tagline">{p.data.tagline}</span>
                        <span class="item__status">{p.data.status}</span>
                      </button>
                    ))}
                  </div>
                );
              })}
            </div>
          ))
        }
      </aside>

      <!-- 右栏：详情 -->
      <main class="detail" aria-label="项目详情">
        <button class="detail__back" type="button">← 返回列表</button>
        {
          rendered.map(({ p, Content }) => (
            <div
              class="panel"
              data-slug={p.id}
              data-domain={p.data.domain}
              hidden={p.id !== firstActive.id}
            >
              <ProjectDetail project={p}>
                <Content />
              </ProjectDetail>
            </div>
          ))
        }
      </main>
    </div>

    <div class="resume-overlay" id="docReader" hidden>
      <div class="resume-modal" role="dialog" aria-modal="true">
        <div class="resume-modal__bar">
          <span class="resume-modal__title" id="docTitle">文档</span>
          <div class="resume-modal__actions">
            <a class="resume-modal__dl" id="docDownload" href="#" download>
              下载原文件
            </a>
            <button class="resume-modal__close" id="docClose" type="button" aria-label="关闭">
              ×
            </button>
          </div>
        </div>
        <iframe class="resume-modal__frame" id="docFrame" title="文档阅读" src="about:blank"
        ></iframe>
      </div>
    </div>
  </div>
</AppLayout>

<style>
  .app {
    height: 100vh;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* 顶栏 */
  .topbar {
    flex-shrink: 0;
    height: 64px;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-inline: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .brand {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .brand__name {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .brand__dot {
    color: var(--color-accent);
  }
  .brand__role {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .tabs {
    display: flex;
    gap: 0.4rem;
    margin-left: var(--space-2);
  }
  .tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1.1rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--dur) var(--ease);
  }
  .tab:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }
  .tab.is-active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .tab__count {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    opacity: 0.7;
  }

  .contact {
    margin-left: auto;
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .contact a:hover {
    color: var(--color-accent);
  }

  /* 文档在线阅读弹层（财报 / 研究报告）*/
  .resume-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3);
    background: rgba(15, 17, 23, 0.55);
    backdrop-filter: blur(4px);
  }
  .resume-overlay[hidden] {
    display: none;
  }
  .resume-modal {
    width: 100%;
    max-width: 860px;
    height: 92vh;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .resume-modal__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }
  .resume-modal__title {
    font-weight: 700;
  }
  .resume-modal__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .resume-modal__dl {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
  }
  .resume-modal__dl:hover {
    text-decoration: underline;
  }
  .resume-modal__close {
    width: 32px;
    height: 32px;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    background: var(--color-bg);
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
    color: var(--color-text-muted);
  }
  .resume-modal__close:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }
  .resume-modal__frame {
    flex: 1;
    width: 100%;
    border: 0;
  }

  /* 主体两栏 */
  .main {
    flex: 1;
    display: flex;
    min-height: 0;
  }
  .sidebar {
    width: 340px;
    flex-shrink: 0;
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
    padding: var(--space-3);
    background: var(--color-bg-subtle);
  }
  .list-cat {
    margin-bottom: var(--space-3);
  }
  .list-cat__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    padding: var(--space-1) var(--space-1) var(--space-1);
    margin-bottom: 0.3rem;
  }
  .item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    width: 100%;
    text-align: left;
    padding: var(--space-2);
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    background: transparent;
    cursor: pointer;
    transition: all var(--dur) var(--ease);
    margin-bottom: 0.3rem;
  }
  .item:hover {
    background: var(--color-bg);
    border-color: var(--color-border);
  }
  .item.is-active {
    background: var(--color-bg);
    border-color: var(--color-accent);
    box-shadow: inset 3px 0 0 var(--color-accent);
  }
  .item__title {
    font-size: var(--text-base);
    font-weight: 650;
    color: var(--color-text);
  }
  .item__tagline {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .item__status {
    font-size: 0.7rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  .detail {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-6) var(--space-5) var(--space-12);
  }
  .detail__back {
    display: none;
    margin-bottom: var(--space-3);
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-pill);
    background: var(--color-bg);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
  }

  /* —— 移动端：单栏切换 —— */
  @media (max-width: 860px) {
    .app {
      height: auto;
      min-height: 100dvh;
      overflow: visible;
    }
    .topbar {
      flex-wrap: wrap;
      height: auto;
      padding-block: var(--space-2);
      gap: var(--space-2);
    }
    .brand__role {
      display: none;
    }
    .contact {
      display: none;
    }
    .tabs {
      margin-left: 0;
      flex: 1;
    }
    .main {
      display: block;
    }
    .sidebar {
      width: 100%;
      border-right: none;
      max-height: none;
      overflow: visible;
    }
    .detail {
      padding: var(--space-4) var(--space-3) var(--space-8);
    }
    .detail__back {
      display: inline-block;
    }
    /* 列表态：显示列表，隐藏详情 */
    .app[data-mobile-view="list"] .detail {
      display: none;
    }
    /* 详情态：隐藏列表，显示详情 */
    .app[data-mobile-view="detail"] .sidebar {
      display: none;
    }
  }
</style>

<script>
  const app = document.querySelector<HTMLElement>(".app")!;
  const tabs = Array.from(document.querySelectorAll<HTMLElement>(".tab"));
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>(".list-group"),
  );
  const items = Array.from(document.querySelectorAll<HTMLElement>(".item"));
  const panels = Array.from(document.querySelectorAll<HTMLElement>(".panel"));
  const detail = document.querySelector<HTMLElement>(".detail")!;
  const backBtn = document.querySelector<HTMLElement>(".detail__back");

  function selectItem(slug: string) {
    items.forEach((i) => i.classList.toggle("is-active", i.dataset.slug === slug));
    panels.forEach((p) => (p.hidden = p.dataset.slug !== slug));
    detail.scrollTop = 0;
    app.dataset.mobileView = "detail";
  }

  function selectTab(domain: string) {
    tabs.forEach((t) => {
      const on = t.dataset.tab === domain;
      t.classList.toggle("is-active", on);
      t.setAttribute("aria-selected", on ? "true" : "false");
    });
    groups.forEach((g) => (g.hidden = g.dataset.domain !== domain));
    const first = items.find((i) => i.dataset.domain === domain);
    if (first) selectItem(first.dataset.slug!);
    // 切 tab 回到列表态（移动端）
    app.dataset.mobileView = "list";
  }

  tabs.forEach((t) =>
    t.addEventListener("click", () => selectTab(t.dataset.tab!)),
  );
  items.forEach((i) =>
    i.addEventListener("click", () => selectItem(i.dataset.slug!)),
  );
  backBtn?.addEventListener("click", () => (app.dataset.mobileView = "list"));

  // 站内文档阅读器（简历 / 完整报告通用）
  const docReader = document.getElementById("docReader");
  const docFrame = document.getElementById("docFrame") as HTMLIFrameElement | null;
  const docTitle = document.getElementById("docTitle");
  const docDownload = document.getElementById("docDownload") as HTMLAnchorElement | null;

  function openDoc(src: string, title: string, download: string) {
    if (!docReader || !docFrame) return;
    docFrame.src = src;
    if (docTitle) docTitle.textContent = title || "文档";
    if (docDownload) {
      if (download) {
        docDownload.href = download;
        docDownload.hidden = false;
      } else {
        docDownload.hidden = true;
      }
    }
    docReader.hidden = false;
  }
  function closeDoc() {
    if (!docReader) return;
    docReader.hidden = true;
    if (docFrame) docFrame.src = "about:blank";
  }

  document.querySelectorAll<HTMLElement>("[data-doc-src]").forEach((b) =>
    b.addEventListener("click", (e) => {
      e.preventDefault();
      openDoc(b.dataset.docSrc!, b.dataset.docTitle ?? "文档", b.dataset.docDownload ?? "");
    }),
  );
  document.getElementById("docClose")?.addEventListener("click", closeDoc);
  docReader?.addEventListener("click", (e) => {
    if (e.target === docReader) closeDoc();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && docReader && !docReader.hidden) closeDoc();
  });
</script>
