---
import { Image } from "astro:assets";
import MetricStat from "./MetricStat.astro";
import Gallery from "./Gallery.astro";
import { categories, domains } from "../data/site";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const d = project.data;

const domainLabel = domains.find((x) => x.key === d.domain)?.label ?? "";
const categoryLabel = categories.find((x) => x.key === d.category)?.label ?? "";

const linkLabels: Record<string, string> = {
  live: "在线访问",
  demo: "交互 Demo",
  github: "源码",
  download: "下载完整报告",
};
// read 用站内阅读器打开；有 read 时下载入口移到阅读器内，header 不再单列 download
const linkEntries = Object.entries(d.links).filter(
  ([k, v]) => v && k !== "read" && !(k === "download" && d.links.read),
);

// 品牌概念卡底色——莫兰迪低饱和（card1 雾霾蓝灰 / card2 暖陶灰）
const heroGradients = [
  "linear-gradient(150deg, #cdd5d6, #bcc7c9)",
  "linear-gradient(150deg, #dccfc4, #cebcae)",
];
---

<article class="pd">
  <header class="pd__header">
    <span class="pd__tag">{domainLabel} · {categoryLabel}</span>
    <h2 class="pd__title">{d.title}</h2>
    <p class="pd__tagline">{d.tagline}</p>

    {
      (linkEntries.length > 0 || d.links.read) && (
        <div class="pd__links">
          {d.links.read && (
            <a
              class="btn btn--primary"
              href={d.links.read}
              target="_blank"
              rel="noopener"
              data-doc-src={d.links.read}
              data-doc-title={`${d.title} · 完整报告`}
              data-doc-download={d.links.download ?? ""}
            >
              在线阅读完整报告 ↗
            </a>
          )}
          {linkEntries.map(([key, val]) => (
            <a class="btn btn--ghost" href={val} target="_blank" rel="noopener">
              {linkLabels[key] ?? key} ↗
            </a>
          ))}
        </div>
      )
    }
  </header>

  {
    d.video ? (
      <div class="pd__cover">
        <video controls preload="metadata" poster={d.video.poster}>
          <source src={d.video.src} type="video/mp4" />
        </video>
      </div>
    ) : d.heroCards.length > 0 ? (
      <div class="pd__hero-cards">
        {d.heroCards.map((c, i) => (
          <div
            class="hero-card"
            style={`background:${heroGradients[i % heroGradients.length]}`}
          >
            <span class="hero-card__emoji">{c.emoji}</span>
            <h3 class="hero-card__title">{c.title}</h3>
            <p class="hero-card__sub">{c.subtitle}</p>
          </div>
        ))}
      </div>
    ) : d.reports.length > 0 ? (
      <div class="pd__reports">
        {d.reports.map((r) => (
          <a
            class="report-card"
            href={r.read}
            target="_blank"
            rel="noopener"
            data-doc-src={r.read}
            data-doc-title={r.label}
            data-doc-download={r.download ?? ""}
          >
            <div class="report-card__img">
              <Image
                src={r.cover}
                alt={r.label}
                widths={[300, 600]}
                sizes="(max-width: 720px) 90vw, 380px"
              />
            </div>
            <span class="report-card__label">
              {r.label}
              <em>在线阅读 ↗</em>
            </span>
          </a>
        ))}
      </div>
    ) : d.cover ? (
      <div class="pd__cover">
        <Image
          src={d.cover}
          alt={d.title}
          widths={[600, 1000, 1400]}
          sizes="(max-width: 1080px) 100vw, 860px"
        />
      </div>
    ) : d.gallery.length > 0 ? (
      <div class="pd__hero-gallery">
        <Gallery items={d.gallery} />
      </div>
    ) : null
  }

  {
    d.metrics.length > 0 && (
      <div class="pd__metrics">
        {d.metrics.map((m) => (
          <MetricStat value={m.value} label={m.label} />
        ))}
      </div>
    )
  }

  <div class="pd__overview">
    <div class="callout">
      <h3>解决的问题</h3>
      <p>{d.problem}</p>
    </div>
    <div class="callout callout--accent">
      <h3>核心 AI 能力</h3>
      <p>{d.aiCapability}</p>
    </div>
  </div>

  <div class="prose">
    <slot />
  </div>

  {
    (d.cover || d.heroCards.length > 0) && d.gallery.length > 0 && (
      <section class="pd__block">
        <h3 class="block-title">对话交互 · 项目图集</h3>
        <Gallery items={d.gallery} />
      </section>
    )
  }
</article>

<style>
  .pd {
    max-width: 860px;
    margin: 0 auto;
  }
  .pd__tag {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-2);
  }
  .pd__title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-2);
  }
  .pd__tagline {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }
  .pd__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .pd__cover {
    margin-block: var(--space-6);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
    display: flex;
    justify-content: center;
    background: var(--color-bg-subtle);
  }
  .pd__cover img {
    width: auto;
    max-width: 100%;
    max-height: 560px;
    height: auto;
    object-fit: contain;
  }
  .pd__cover video {
    width: 100%;
    display: block;
  }
  .pd__hero-gallery {
    margin-block: var(--space-6);
  }

  .pd__hero-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    margin-block: var(--space-6);
  }
  .hero-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-2);
    min-height: 230px;
    padding: var(--space-5);
    border-radius: var(--radius);
    color: #2b2b2b;
    border: 1px solid rgba(0, 0, 0, 0.06);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .hero-card__emoji {
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: var(--space-2);
    opacity: 0.9;
  }
  .hero-card__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: #2b2b2b;
    margin: 0;
  }
  .hero-card__sub {
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    color: rgba(43, 43, 43, 0.66);
  }
  @media (max-width: 640px) {
    .pd__hero-cards {
      grid-template-columns: 1fr;
    }
    .hero-card {
      min-height: 180px;
    }
  }

  .pd__reports {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    margin-block: var(--space-6);
  }
  .report-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-bg);
    transition: all var(--dur) var(--ease);
  }
  .report-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }
  .report-card__img {
    height: 300px;
    overflow: hidden;
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
  }
  .report-card__img :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }
  .report-card__label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    font-weight: 650;
    font-size: var(--text-base);
  }
  .report-card__label em {
    font-style: normal;
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-accent);
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .pd__reports {
      grid-template-columns: 1fr;
    }
  }

  .pd__metrics {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-start;
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-6);
  }
  @media (max-width: 640px) {
    .pd__metrics {
      flex-wrap: wrap;
      gap: var(--space-3) var(--space-4);
    }
  }

  .pd__overview {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }
  .callout {
    padding: var(--space-3);
    border-radius: var(--radius);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
  }
  .callout--accent {
    background: var(--color-accent-subtle);
    border-color: color-mix(in srgb, var(--color-accent) 18%, transparent);
  }
  .callout h3 {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .block-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--color-border);
  }
  .pd__block {
    margin-top: var(--space-6);
  }

  @media (max-width: 640px) {
    .pd__overview {
      grid-template-columns: 1fr;
    }
    .pd__title {
      font-size: var(--text-3xl);
    }
  }
</style>

<style is:global>
  /* MDX 正文排版 */
  .prose {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-text);
  }
  .prose > * + * {
    margin-top: var(--space-3);
  }
  .prose h2 {
    font-size: var(--text-2xl);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }
  .prose h3 {
    font-size: var(--text-xl);
    margin-top: var(--space-5);
  }
  .prose ul,
  .prose ol {
    padding-left: 1.25rem;
  }
  .prose ul {
    list-style: disc;
  }
  .prose ol {
    list-style: decimal;
  }
  .prose li + li {
    margin-top: 0.5rem;
  }
  .prose strong {
    font-weight: 650;
  }
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.1rem 0.4rem;
  }
  .prose pre {
    background: var(--color-bg-subtle) !important;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3);
    overflow-x: auto;
    font-size: var(--text-sm);
    line-height: 1.6;
  }
  .prose pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }
  .prose table {
    border-collapse: collapse;
    width: 100%;
    margin: var(--space-3) 0;
    font-size: var(--text-sm);
  }
  .prose th,
  .prose td {
    border: 1px solid var(--color-border);
    padding: 0.55rem 0.85rem;
    text-align: left;
    vertical-align: top;
  }
  .prose th {
    background: var(--color-accent-subtle);
    color: var(--color-accent);
    font-weight: 600;
  }
  .prose tbody tr:nth-child(even) td {
    background: #fafbff;
  }
  .prose td:first-child {
    font-weight: 600;
    white-space: nowrap;
    color: var(--color-accent);
  }
  .prose blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-3);
    color: var(--color-text-muted);
    font-style: italic;
  }
  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
